rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function roleTier() {
      // Use new roleTier field, fall back to role for backward compatibility during transition
      return userDoc().data.roleTier ?? userDoc().data.role;
    }

    function role() {
      // Deprecated: use roleTier() instead
      return roleTier();
    }

    function isAdmin() {
      return isSignedIn() && roleTier() == 'admin';
    }

    function isSrGuard() {
      return isSignedIn() && (roleTier() == 'admin' || roleTier() == 'sr_guard');
    }

    function isStaff() {
      return isSignedIn() && (roleTier() == 'admin' || roleTier() == 'sr_guard' || roleTier() == 'pool_tech' || roleTier() == 'lifeguard');
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isStaff();
      allow create: if isAdmin();
      allow update: if isAdmin() || isSrGuard();
      allow delete: if isAdmin();
    }

    match /audits/{auditId} {
      allow read: if isSrGuard();
      allow create: if isSrGuard();
      allow update, delete: if isAdmin();
    }

    match /history/{historyId} {
      allow read: if isAdmin();
      allow create: if isSrGuard();
      allow update, delete: if isAdmin();
    }

    match /documents/{docId} {
      // DEPRECATED: This collection is being migrated to documents_library
      // Keeping read access for backwards compatibility during migration
      allow read: if isStaff();
      allow create, update, delete: if false; // No new writes to old collection
    }

    // PHASE 1C: New documents collection (replaces documents_library)
    // Using 'documents' as canonical collection name with final schema
    // For now, this rule is placeholder; will be activated in Phase 1C migration
    // TODO: This will replace documents_library after successful migration
    // match /documents/{docId} {
    //   allow read: if isStaff() && (
    //     resource.data.visibility == 'all_staff' ||
    //     roleTier() in resource.data.accessRoles
    //   );
    //   allow create, update: if isAdmin();
    //   allow delete: if isAdmin();
    // }

    match /task_completions/{taskId} {
      allow read, write: if isStaff();
    }

    match /shift_tasks/{taskId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /shift_checklists/{checklistId} {
      // Ownership check: stored in ownerUid field instead of parsing the ID
      allow read: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid || 
        isAdmin() || 
        isSrGuard()
      );
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid || 
        isAdmin() || 
        isSrGuard()
      );
      allow delete: if isAdmin();
    }

    match /positions/{id} {
      // Position definitions (admin-managed job titles and roles)
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /inventory_entries/{id} {
      // Inventory tracking (chemicals, supplies, equipment)
      allow read: if isStaff();
      allow create, update: if isAdmin() || isSrGuard();
      allow delete: if isAdmin();
    }

    match /staff_forms/{formId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // Document Library & Archives
    // documents_library: main document storage with role-based access
    // NOTE: During Phase 1C, this transitions to 'documents' collection
    match /documents_library/{docId} {
      // Allow read if user is staff AND:
      // - visibility is 'all_staff', OR
      // - user's roleTier is in the accessRoles array
      allow read: if isStaff() && (
        resource.data.visibility == 'all_staff' ||
        roleTier() in resource.data.accessRoles
      );
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /document_templates/{templateId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /document_archives/{archiveId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /staff_forms_submissions/{submissionId} {
      allow read: if request.auth.uid == resource.data.staffId || isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth.uid == resource.data.staffId && resource.data.status == 'draft');
      allow delete: if isAdmin();
    }

    match /checklists_library/{checklistId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /incident_reports_archive/{reportId} {
      allow read: if isSrGuard();
      allow create, update: if isSrGuard();
      allow delete: if isAdmin();
    }

    match /senior_lifeguard_resources/{resourceId} {
      allow read: if isSrGuard();
      allow create, update, delete: if isAdmin();
    }

    // Certification system (Phase 3A)
    match /cert_templates/{templateId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /staff_certifications/{certId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.staffUid ||
        isAdmin() ||
        isSrGuard()
      );
      allow create: if isAdmin();
      allow update: if isAdmin() || (request.auth.uid == resource.data.staffUid && resource.data.status == 'draft');
      allow delete: if isAdmin();
    }

    // Senior profiles (Phase 3B)
    match /senior_profiles/{profileId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
